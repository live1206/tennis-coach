{
  "validation_set": "baseline-30",
  "model": {
    "name": "TrackNet V1 unofficial PyTorch checkpoint",
    "source": "https://github.com/yastrebksv/TrackNet",
    "checkpoint_redistributed": false
  },
  "inference": {
    "frame_step": 4,
    "temporal_stride": 2,
    "evaluated_frames": 30,
    "tolerance_pixels": 10.0
  },
  "metrics": {
