    "mean_localization_error": 4.330883,
    "median_localization_error": 4.274695
  },
  "limitations": [
    "Single two-second clip from one camera and court.",
    "All labeled frames contain a visible ball, so false-positive behavior is not covered.",
    "This is an initial smoke validation set, not a release-quality benchmark."
  ]
